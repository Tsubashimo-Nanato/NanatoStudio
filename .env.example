# Nanato Studio local environment example
#
# Frontend variables prefixed with PUBLIC_ are read at Astro build/dev time.
# Leave both values blank for the default behavior:
# - Astro dev on 127.0.0.1:4321 calls http://127.0.0.1:8000 directly.
# - production-like same-origin deployments call /api through the reverse proxy.

# Force a specific backend for Astro dev, for example:
# PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Force same-origin proxy mode for production-like local builds:
# PUBLIC_API_MODE=same-origin
# PUBLIC_API_BASE_URL=/api

# Backend settings
DATABASE_URL=sqlite:///./nanatostudio.db
SECRET_KEY=replace-this-local-secret-with-a-long-random-value
CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321,http://localhost:8080,http://127.0.0.1:8080
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_NAME=nanato_session
SESSION_TTL_HOURS=24
