---
---

<div class="auth-card auth-card--interactive">
  <div class="auth-card__header">
    <span>Nanato Studio account</span>
    <strong>Sign in</strong>
    <p>Use your local backend account. The challenge below comes from FastAPI.</p>
  </div>

  <form class="auth-form auth-form--stacked" data-auth-form data-auth-mode="login" novalidate>
    <div class="form-status form-status--neutral" data-auth-message aria-live="polite">
      Enter your details and solve the challenge.
    </div>

    <label>
      Username or email
      <input
        type="text"
        name="username_or_email"
        autocomplete="username"
        placeholder="username or you@example.com"
        required
      />
    </label>

    <label>
      Password
      <input type="password" name="password" autocomplete="current-password" placeholder="Password" required />
    </label>

    <fieldset class="challenge-box" data-challenge-box>
      <legend>Human verification</legend>
      <div class="challenge-box__question">
        <span data-challenge-question>Loading challenge...</span>
        <button class="text-button" type="button" data-challenge-reload>Retry challenge</button>
      </div>
      <input type="hidden" name="challenge_id" data-challenge-id />
      <label>
        Answer
        <input
          type="text"
          name="challenge_answer"
          inputmode="numeric"
          autocomplete="off"
          placeholder="Type the answer"
          required
        />
      </label>
    </fieldset>

    <button class="button button--primary auth-submit" type="submit" data-auth-submit>Sign in</button>
  </form>

  <div class="auth-card__footer" aria-label="Login links">
    <a class="button button--subtle auth-card__secondary-action" href="/register/">Create account</a>
    <a class="text-link" href="/">Back to public site</a>
  </div>
</div>
