---
import BaseLayout from "../../layouts/BaseLayout.astro";

const apps = [
  {
    name: "Tsubashimo-Nanato",
    shortName: "GitHub profile",
    status: "Source hub",
    type: "Personal GitHub index",
    repo: "https://github.com/Tsubashimo-Nanato",
    version: "GitHub",
    stack: ["Profile", "Repositories", "Source", "Public"],
    description:
      "The public GitHub shelf for Nanato's source work, repositories, experiments, and project entry points.",
    features: [
      "Collects public repositories in one source-first profile.",
      "Keeps app source links close to the public studio site.",
      "Acts as the top-level entry point before individual project repositories."
    ],
    command: "open github.com/Tsubashimo-Nanato",
    links: [{ label: "Open GitHub", href: "https://github.com/Tsubashimo-Nanato" }]
  },
  {
    name: "ros2unbag",
    shortName: "ROS bag inspector",
    status: "Released",
    type: "Windows ROS 2 bag inspector",
    repo: "https://github.com/Tsubashimo-Nanato/ros2unbag",
    version: "v1.5.1",
    stack: ["Python", "ROS bags", "CLI", "PySide6"],
    description:
      "Offline ROS bag inspection for Windows workflows: topics, timestamp indexing, selected exports, and shell navigation without launching a full ROS environment.",
    features: [
      "Exports CSV, Parquet, SQLite, JSONL, NPZ, raw dumps, image sequences, MP4, PCD, and PLY.",
      "Interactive shell includes topic navigation, tab completion, selected exports, and progress display.",
      "View-only GUI timeline shell keeps inspection non-destructive."
    ],
    command: "ros2unbag topics .\\my_bag",
    links: [{ label: "Repository", href: "https://github.com/Tsubashimo-Nanato/ros2unbag" }]
  },
  {
    name: "AndroidHealthConnect",
    shortName: "Health data lab",
    status: "Active",
    type: "Android client and API server",
    repo: "https://github.com/Tsubashimo-Nanato/AndroidHealthConnect",
    version: "0.1.0",
    stack: ["Kotlin", "Health Connect", ".NET 8", "C#"],
    description:
      "A compact Android Health Connect client paired with a small .NET API server for local mobile-health data experiments and service integration work.",
    features: [
      "Android Gradle project under AndroidClient.",
      ".NET 8 API project under Server.",
      "Generated builds, local SDK config, databases, logs, and runtimes stay out of source control."
    ],
    command: ".\\gradlew.bat :app:assembleDebug",
    links: [{ label: "Repository", href: "https://github.com/Tsubashimo-Nanato/AndroidHealthConnect" }]
  }
];

const shelfStats = [
  { label: "Public tools", value: String(apps.length) },
  { label: "Open source", value: "3 links" },
  { label: "Primary hub", value: "GitHub" }
];
---

<BaseLayout title="Apps" description="Nanato Studio app shelf for released tools, mobile experiments, and technical utilities." pageClass="entry-page apps-page">
  <section class="apps-bench page-enter" aria-labelledby="apps-title">
    <div class="apps-bench__intro">
      <p class="eyebrow">Apps shelf</p>
      <h1 id="apps-title">Small tools on the edge of the desk.</h1>
      <p>
        Public utilities stay inspectable here: what they do, how to start them, and where the source lives.
      </p>
      <div class="apps-bench__stats" aria-label="Apps shelf summary">
        {
          shelfStats.map((stat) => (
            <span>
              <strong>{stat.value}</strong>
              {stat.label}
            </span>
          ))
        }
      </div>
    </div>

    <div class="apps-bench__float" aria-label="Floating app index">
      {
        apps.map((app, index) => (
          <a
            class:list={[
              "apps-bench__float-card",
              index === 1 && "apps-bench__float-card--middle",
              index === 2 && "apps-bench__float-card--lower"
            ]}
            href={`#${app.name.toLowerCase()}`}
            data-float-repel
          >
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{app.name}</strong>
            <small>{app.shortName}</small>
          </a>
        ))
      }
    </div>
  </section>

  <section class="apps-ledger page-enter page-enter--delay-1" aria-label="App details">
    {
      apps.map((app, index) => (
        <details class="apps-tool" id={app.name.toLowerCase()} open={index === 0} data-float-repel>
          <summary>
            <span class="apps-tool__number">{String(index + 1).padStart(2, "0")}</span>
            <span class="apps-tool__title">
              <span>{app.status}</span>
              <strong>{app.name}</strong>
              <small>{app.type}</small>
            </span>
            <span class="apps-tool__version">{app.version}</span>
          </summary>

          <div class="apps-tool__body">
            <p>{app.description}</p>
            <div class="apps-tool__stack" aria-label={`${app.name} stack`}>
              {app.stack.map((item) => <span>{item}</span>)}
            </div>
            <div class="apps-tool__details">
              <ul>
                {app.features.map((feature) => <li>{feature}</li>)}
              </ul>
              <aside>
                <span>Start</span>
                <code>{app.command}</code>
                {app.links.map((link) => (
                  <a class="text-link" href={link.href} target="_blank" rel="noreferrer">
                    {link.label}
                  </a>
                ))}
              </aside>
            </div>
          </div>
        </details>
      ))
    }
  </section>
</BaseLayout>
