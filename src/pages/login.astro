---
import AuthForm from "../components/AuthForm.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Login" description="Sign in to Nanato Studio with the FastAPI account backend." pageClass="entry-page login-page">
  <section class="auth-station page-enter" aria-labelledby="login-title">
    <div class="auth-station__note">
      <p class="eyebrow">Account access</p>
      <h1 id="login-title">Studio key</h1>
      <p>
        Sign in once to open the dashboard, assigned Markdown editor, and admin tools allowed by the backend session.
      </p>
      <div class="auth-station__list" aria-label="Login access">
        <span>HttpOnly session</span>
        <span>Editor permissions</span>
        <span>Local API check</span>
      </div>
    </div>

    <AuthForm />
  </section>
</BaseLayout>
