---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegisterForm from "../components/RegisterForm.astro";
---

<BaseLayout title="Register" description="Create a Nanato Studio account through backend validation." pageClass="entry-page register-page">
  <section class="utility-hero auth-shell page-enter" aria-labelledby="register-title">
    <div class="utility-copy">
      <p class="eyebrow">Account registration</p>
      <h1 id="register-title">Create account.</h1>
      <p>
        Set up a workspace login for writing, maintaining docs, and managing your studio content.
      </p>
      <div class="status-row" aria-label="Registration validation">
        <span>Profile</span>
        <span>Email</span>
        <span>Verification</span>
      </div>
    </div>

    <RegisterForm />
  </section>
</BaseLayout>
